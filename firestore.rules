rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // SECURITY: Shared content collections - read-only for all authenticated users
    // Only specific documents that should be shared globally
    match /appData/sharedContent {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // SECURITY: Shared posts feed - readable and writable by all authenticated users
    match /appData/posts {
      allow read, write: if signedIn();
    }

    match /appData/friendSuggestions {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // SECURITY: Moderation reports - write-only for authenticated users
    match /appData/moderationReports {
      allow read: if false;
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // SECURITY: Shared chat rooms - aggregate document with member filtering
    // Client-side filtering enforces that users only see rooms they're a member of
    // Firestore rules prevent unauthorized document writes
    match /appData/chatRooms {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // SECURITY: Registry of deleted user UIDs, readable by all authenticated users
    match /appData/deletedUsers {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // SECURITY: Deny global access to other appData documents
    match /appData/{document=**} {
      allow read, write: if false;
    }

    // Login resolves email from username/phone before sign-in, so reads must
    // stay public with the current client-side auth flow.
    match /userHandles/{handleId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
      allow delete: if signedIn();
    }

    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if ownsUser(userId);
      allow delete: if signedIn();

      match /appData/{docId} {
        allow read, create, update: if ownsUser(userId);
        allow delete: if signedIn();
      }

      match /calendarEvents/{eventId} {
        allow read, create, update: if ownsUser(userId);
        allow delete: if signedIn();
      }
    }
  }
}